# Telegram Bot Configuration
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_DEBUG=false

# Database Configuration
DB_PATH=./finance.db

# Redis Configuration
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# App Configuration
TZ=Europe/Moscow
CLEANUP_MONTHS=3
REPORT_HOUR=0
REPORT_MINUTE=0

# Limit Thresholds (in percentages)
LIMIT_WARNING_THRESHOLD=80.0
LIMIT_OVERLOAD_THRESHOLD=100.0
BALANCE_WARNING_THRESHOLD=10.0

# Date and Time Formats (Go format)
DATE_FORMAT=2006-01-02
MONTH_FORMAT=2006-01
TIME_FORMAT=15:04

# Currency and Display
CURRENCY_SYMBOL=₽

# Status Emojis
EMOJI_SUCCESS=✅
EMOJI_WARNING=🟡
EMOJI_ERROR=❌
EMOJI_BALANCE_GOOD=🟢
EMOJI_BALANCE_WARNING=🟡
EMOJI_BALANCE_BAD=🔴

# Confirmation Words (comma-separated)
CONFIRMATION_WORDS=да,yes

# Language Configuration
LANGUAGES=ru,en
DEFAULT_LANGUAGE=en
